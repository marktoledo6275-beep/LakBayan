  m_Script: {fileID: 11500000, guid: 06c10d7ed1426024bac4536e33c4c923, type: 3}
  m_Name: Elder_Offer
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  speakerName: Village Elder
  lines:
  - text: Cross the bridge and visit the river shrine to the east.
    showAsHistoricalFact: 0
  - text: Many pre-colonial communities settled near rivers because waterways supported
      fishing, farming, and trade.
    showAsHistoricalFact: 1
  - text: Return to me after you reach it.
    showAsHistoricalFact: 0
